# 复制为 .env 并修改（生产环境必填）
SECRET_KEY=请替换为随机长字符串
JWT_SECRET=请替换为另一随机长字符串
ADMIN_USER=admin
ADMIN_PASS=请替换为强密码
DEV_MODE=false
FLASK_DEBUG=false
PUBLIC_URL=https://ggtaiqiu.com
CORS_ORIGINS=https://ggtaiqiu.com,http://127.0.0.1:5000,http://localhost:5000

# MySQL（云托管内网；本地不配置则继续用 JSON 文件）
# MYSQL_HOST=10.4.106.26
# MYSQL_PORT=3306
# MYSQL_USER=ggtaiqiu_app
# MYSQL_PASSWORD=请替换
# MYSQL_DATABASE=ggtaiqiu
# USE_MYSQL=true

# 微信云托管（在服务设置-环境变量中配置，勿提交真实值）
# PORT=80
# HOST=0.0.0.0
# WECHAT_APPID=
# WECHAT_SECRET=
# PUBLIC_URL=https://ggtaiqiu.com
# CORS_ORIGINS=https://ggtaiqiu.com
