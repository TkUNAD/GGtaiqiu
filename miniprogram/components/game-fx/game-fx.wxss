.fx-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 9999;
  background: rgba(4, 6, 12, 0.94);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.fx-scene {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ========== 胜：行书金属 红黄 下落弹跳燃烧 4s（加大） ========== */
.fx-win {
  flex-direction: column;
}

.fx-art-win {
  position: relative;
  z-index: 6;
  font-size: 380rpx;
  font-weight: 900;
  font-family: STXingkai, KaiTi, STKaiti, "华文行楷", serif;
  letter-spacing: 20rpx;
  line-height: 1;
  background: linear-gradient(
    165deg,
    #fffef0 0%,
    #fde047 12%,
    #f59e0b 28%,
    #ea580c 48%,
    #dc2626 68%,
    #fbbf24 88%,
    #fef3c7 100%
  );
  -webkit-background-clip: text;
  color: transparent;
  -webkit-text-stroke: 3rpx rgba(254, 243, 199, 0.55);
  filter:
    drop-shadow(0 6rpx 0 rgba(127, 29, 29, 0.9))
    drop-shadow(0 0 64rpx rgba(251, 191, 36, 0.9))
    drop-shadow(0 0 120rpx rgba(239, 68, 68, 0.6));
  animation: win-drop-bounce 4s cubic-bezier(0.22, 0.85, 0.28, 1) forwards;
}

@keyframes win-drop-bounce {
  0% {
    transform: translateY(-110vh) scale(1.2) rotate(-6deg);
    opacity: 0;
  }
  6% { opacity: 1; }
  42% {
    transform: translateY(0) scale(1) rotate(0deg);
  }
  50% {
    transform: translateY(-88rpx) scale(1.05);
  }
  58% {
    transform: translateY(0) scale(1);
  }
  64% {
    transform: translateY(-44rpx) scale(1.03);
  }
  70% {
    transform: translateY(0) scale(1);
  }
  100% {
    transform: translateY(0) scale(1);
    opacity: 1;
  }
}

.fx-win-flames {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 4;
}

.fx-flame {
  position: absolute;
  left: 50%;
  bottom: 16%;
  transform: translateX(-50%);
  border-radius: 50% 50% 45% 45%;
  opacity: 0;
  filter: blur(2rpx);
}

.fx-flame-1 {
  width: 720rpx;
  height: 500rpx;
  background: radial-gradient(ellipse at bottom, rgba(254, 243, 199, 0.95), rgba(251, 191, 36, 0.7), rgba(239, 68, 68, 0.4), transparent 72%);
  animation: win-flame-rise 2.6s ease-out 1.35s forwards;
}

.fx-flame-2 {
  width: 920rpx;
  height: 600rpx;
  background: radial-gradient(ellipse at bottom, rgba(239, 68, 68, 0.75), rgba(234, 88, 12, 0.45), transparent 70%);
  animation: win-flame-rise 2.6s ease-out 1.45s forwards;
}

.fx-flame-3 {
  width: 560rpx;
  height: 400rpx;
  background: radial-gradient(ellipse at bottom, #fef3c7, #f97316, transparent 68%);
  animation: win-flame-flicker 0.22s ease-in-out 1.4s infinite alternate;
}

@keyframes win-flame-rise {
  0% { opacity: 0; transform: translateX(-50%) scaleY(0.2); }
  25% { opacity: 1; transform: translateX(-50%) scaleY(1.1); }
  100% { opacity: 0.85; transform: translateX(-50%) scaleY(1.25); }
}

@keyframes win-flame-flicker {
  0% { opacity: 0.7; transform: translateX(-50%) scale(0.95); }
  100% { opacity: 1; transform: translateX(-50%) scale(1.08); }
}

.fx-ember {
  position: absolute;
  bottom: 20%;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #fbbf24;
  box-shadow: 0 0 18rpx #f97316;
  opacity: 0;
  animation: ember-fly 1.2s ease-out calc(1.5s + var(--delay)) infinite;
}

@keyframes ember-fly {
  0% { transform: translateY(0) scale(1); opacity: 0; }
  12% { opacity: 1; }
  100% { transform: translateY(-320rpx) scale(0.2); opacity: 0; }
}

/* ========== 平局：巨大银色行书「和」下落抖动 4s ========== */
.fx-draw {
  flex-direction: column;
}

.fx-draw-glow {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 820rpx;
  height: 820rpx;
  margin: -410rpx 0 0 -410rpx;
  border-radius: 50%;
  background: radial-gradient(
    circle,
    rgba(255, 255, 255, 0.35) 0%,
    rgba(192, 192, 192, 0.2) 35%,
    transparent 68%
  );
  opacity: 0;
  animation: draw-glow-pulse 4s ease-out forwards;
  z-index: 4;
  pointer-events: none;
}

@keyframes draw-glow-pulse {
  0% { opacity: 0; transform: scale(0.6); }
  32% { opacity: 0.85; transform: scale(1); }
  100% { opacity: 0.5; transform: scale(1.08); }
}

.fx-art-draw {
  position: relative;
  z-index: 6;
  font-size: 460rpx;
  font-weight: 900;
  font-family: STXingkai, KaiTi, STKaiti, "华文行楷", serif;
  letter-spacing: 28rpx;
  line-height: 1;
  background: linear-gradient(
    168deg,
    #ffffff 0%,
    #f8fafc 8%,
    #e2e8f0 22%,
    #cbd5e1 38%,
    #94a3b8 52%,
    #cbd5e1 68%,
    #f1f5f9 82%,
    #ffffff 100%
  );
  -webkit-background-clip: text;
  color: transparent;
  -webkit-text-stroke: 4rpx rgba(248, 250, 252, 0.75);
  filter:
    drop-shadow(0 8rpx 0 rgba(71, 85, 105, 0.55))
    drop-shadow(0 0 72rpx rgba(226, 232, 240, 0.95))
    drop-shadow(0 0 140rpx rgba(148, 163, 184, 0.65));
  animation: draw-drop-shake 4s cubic-bezier(0.25, 0.9, 0.35, 1) forwards;
}

@keyframes draw-drop-shake {
  0% {
    transform: translateY(-115vh) scale(1.25);
    opacity: 0;
  }
  7% { opacity: 1; }
  32% {
    transform: translateY(0) scale(1);
  }
  /* 抖动 1 */
  38% {
    transform: translateY(-72rpx) scale(1.02);
  }
  44% {
    transform: translateY(0) scale(1);
  }
  /* 抖动 2 */
  50% {
    transform: translateY(-72rpx) scale(1.02);
  }
  56% {
    transform: translateY(0) scale(1);
  }
  /* 抖动 3 */
  62% {
    transform: translateY(-72rpx) scale(1.02);
  }
  68% {
    transform: translateY(0) scale(1);
  }
  100% {
    transform: translateY(0) scale(1);
    opacity: 1;
  }
}

/* ========== 负：行书玻璃浅蓝 下落裂纹碎裂 4s（加大） ========== */
.fx-lose {
  flex-direction: column;
}

.fx-lose-glass {
  position: relative;
  z-index: 5;
  animation:
    lose-drop-impact 4s cubic-bezier(0.25, 0.9, 0.35, 1) forwards,
    lose-glass-break 0.65s ease-in 2.5s forwards;
}

.fx-art-lose {
  display: block;
  font-size: 380rpx;
  font-weight: 900;
  font-family: STXingkai, KaiTi, STKaiti, "华文行楷", serif;
  letter-spacing: 18rpx;
  line-height: 1;
  color: rgba(186, 230, 253, 0.92);
  -webkit-text-stroke: 4rpx rgba(254, 240, 138, 0.55);
  text-shadow:
    0 0 32rpx rgba(254, 240, 138, 0.5),
    0 0 64rpx rgba(125, 211, 252, 0.4),
    0 8rpx 24rpx rgba(15, 23, 42, 0.65);
  background: linear-gradient(
    145deg,
    rgba(224, 242, 254, 0.95) 0%,
    rgba(125, 211, 252, 0.85) 40%,
    rgba(56, 189, 248, 0.75) 100%
  );
  -webkit-background-clip: text;
  opacity: 0.95;
}

@keyframes lose-drop-impact {
  0% {
    transform: translateY(-110vh) scale(1.15);
    opacity: 0;
  }
  8% { opacity: 1; }
  28% {
    transform: translateY(0) scale(1);
  }
  32% {
    transform: translateY(12rpx) scale(0.98);
  }
  36% {
    transform: translateY(0) scale(1);
  }
  100% {
    transform: translateY(0) scale(1);
  }
}

.fx-crack {
  position: absolute;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.85), rgba(148, 163, 184, 0.9), transparent);
  opacity: 0;
  transform-origin: center;
  animation: lose-crack-show 0.55s ease-out forwards;
}

.fx-crack-1 {
  width: 150%;
  height: 5rpx;
  left: -25%;
  top: 36%;
  transform: rotate(-28deg);
  animation-delay: 1.05s;
}
.fx-crack-2 {
  width: 130%;
  height: 4rpx;
  left: -15%;
  top: 50%;
  transform: rotate(18deg);
  animation-delay: 1.15s;
}
.fx-crack-3 {
  width: 100%;
  height: 4rpx;
  left: 0%;
  top: 60%;
  transform: rotate(-42deg);
  animation-delay: 1.22s;
}
.fx-crack-4 {
  width: 80%;
  height: 3rpx;
  left: 15%;
  top: 26%;
  transform: rotate(35deg);
  animation-delay: 1.28s;
}
.fx-crack-5 {
  width: 58%;
  height: 3rpx;
  left: 25%;
  top: 70%;
  transform: rotate(-12deg);
  animation-delay: 1.35s;
}

@keyframes lose-crack-show {
  0% { opacity: 0; transform: scaleX(0); }
  40% { opacity: 1; }
  100% { opacity: 0.95; transform: scaleX(1); }
}

@keyframes lose-glass-break {
  0% { opacity: 1; filter: brightness(1); }
  100% { opacity: 0; transform: scale(1.03); filter: brightness(1.3) blur(3rpx); }
}

.fx-lose-shard {
  position: absolute;
  top: 40%;
  width: var(--sz);
  height: var(--sz);
  background: linear-gradient(135deg, rgba(186, 230, 253, 0.9), rgba(56, 189, 248, 0.5));
  border: 1rpx solid rgba(254, 240, 138, 0.4);
  opacity: 0;
  z-index: 8;
  animation: lose-shard-scatter 1.2s cubic-bezier(0.4, 0, 0.8, 0.5) calc(2.5s + var(--delay)) forwards;
}

@keyframes lose-shard-scatter {
  0% {
    transform: rotate(0deg) translate(0, 0) scale(1);
    opacity: 0;
  }
  10% { opacity: 1; }
  100% {
    transform: rotate(var(--rot)) translate(var(--dist), 400rpx) scale(0.25);
    opacity: 0;
  }
}

/* ========== 升段 ========== */
.fx-tier { flex-direction: column; }

.fx-char-tier {
  font-size: 45rpx;
  letter-spacing: 6rpx;
  color: #D4AF37;
  margin-bottom: 48rpx;
  animation: char-pop 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

.fx-stage {
  position: relative;
  width: 520rpx;
  height: 520rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tier-stage { width: 560rpx; height: 560rpx; }

.tier-img {
  position: absolute;
  width: 360rpx;
  height: 360rpx;
  left: 50%;
  top: 50%;
  margin-left: -180rpx;
  margin-top: -180rpx;
}

.tier-old { animation: tier-old-in 0.6s ease-out forwards; z-index: 2; }

@keyframes tier-old-in {
  0% { transform: scale(0.5); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.tier-old-break { animation: tier-old-break 0.5s ease-in forwards; }

@keyframes tier-old-break {
  100% { transform: scale(0.6) rotate(-12deg); opacity: 0; filter: blur(4rpx); }
}

.tier-new-hide {
  opacity: 0;
  transform: translateY(-400rpx) scale(0.5);
}

.tier-new-drop {
  z-index: 5;
  animation: tier-new-smash 0.65s cubic-bezier(0.34, 1.2, 0.64, 1) forwards;
}

@keyframes tier-new-smash {
  0% { transform: translateY(-420rpx) scale(0.7); opacity: 0; }
  100% { transform: translateY(0) scale(1); opacity: 1; }
}

.tier-smash-flash {
  position: absolute;
  width: 400rpx;
  height: 400rpx;
  left: 50%;
  top: 50%;
  margin: -200rpx 0 0 -200rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(245, 230, 163, 0.9), transparent 70%);
  animation: smash-flash 0.4s ease-out forwards;
  z-index: 4;
}

@keyframes smash-flash {
  100% { transform: scale(1.8); opacity: 0; }
}

.tier-crack {
  position: absolute;
  width: 300rpx;
  height: 6rpx;
  left: 50%;
  top: 50%;
  margin-left: -150rpx;
  margin-top: -3rpx;
  background: linear-gradient(90deg, transparent, #fff, #D4AF37, transparent);
  animation: tier-crack 0.35s ease-out forwards;
  z-index: 3;
}

@keyframes tier-crack {
  100% { transform: scaleX(1.2); opacity: 0; }
}

.tier-fragment {
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  background: rgba(212, 175, 55, 0.6);
  opacity: 0;
  animation: tier-frag 0.6s ease-out var(--delay) forwards;
}

@keyframes tier-frag {
  100% { transform: rotate(var(--rot)) translate(160rpx, 0); opacity: 0; }
}

@keyframes char-pop {
  0% { transform: scale(0.3); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
