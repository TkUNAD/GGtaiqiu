.fx-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 9999;
  background: rgba(4, 6, 14, 0.96);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.fx-scene {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ========== 标题通用 ========== */
.fx-title-wrap {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.fx-title-main {
  display: block;
  font-size: 200rpx;
  font-weight: 900;
  letter-spacing: 24rpx;
  line-height: 1.1;
  font-family: STHeiti, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.fx-title-sub {
  display: block;
  margin-top: 16rpx;
  font-size: 36rpx;
  letter-spacing: 12rpx;
  font-weight: 600;
  opacity: 0.85;
}

/* ========== 胜利 ========== */
.fx-win {
  flex-direction: column;
}

.fx-win-rays {
  position: absolute;
  width: 900rpx;
  height: 900rpx;
  border-radius: 50%;
  background: conic-gradient(
    from 0deg,
    transparent 0deg,
    rgba(251, 191, 36, 0.15) 30deg,
    transparent 60deg,
    rgba(239, 68, 68, 0.12) 90deg,
    transparent 120deg,
    rgba(251, 191, 36, 0.18) 150deg,
    transparent 180deg,
    rgba(234, 88, 12, 0.1) 210deg,
    transparent 240deg,
    rgba(253, 224, 71, 0.2) 270deg,
    transparent 300deg,
    rgba(251, 191, 36, 0.15) 330deg,
    transparent 360deg
  );
  opacity: 0;
  animation: win-rays-in 4s ease-out forwards, win-rays-spin 8s linear 0.5s infinite;
}

@keyframes win-rays-in {
  0% { opacity: 0; transform: scale(0.3); }
  25% { opacity: 1; transform: scale(1); }
  100% { opacity: 0.7; transform: scale(1.1); }
}

@keyframes win-rays-spin {
  100% { transform: rotate(360deg); }
}

.fx-win-burst {
  position: absolute;
  width: 600rpx;
  height: 600rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(253, 224, 71, 0.55) 0%, rgba(239, 68, 68, 0.25) 40%, transparent 70%);
  animation: win-burst-pulse 4s ease-out forwards;
}

@keyframes win-burst-pulse {
  0% { transform: scale(0); opacity: 0; }
  20% { transform: scale(1.2); opacity: 1; }
  50% { transform: scale(1); opacity: 0.9; }
  100% { transform: scale(1.15); opacity: 0.5; }
}

.fx-title-win .fx-title-main {
  color: #fef08a;
  text-shadow:
    0 0 40rpx rgba(251, 191, 36, 1),
    0 0 80rpx rgba(239, 68, 68, 0.8),
    0 8rpx 0 #b45309,
    0 16rpx 32rpx rgba(0, 0, 0, 0.5);
  animation: win-title-in 4s cubic-bezier(0.22, 0.9, 0.3, 1) forwards;
}

.fx-title-win .fx-title-sub {
  color: #fde68a;
  animation: win-sub-in 4s ease-out 0.2s forwards;
  opacity: 0;
}

@keyframes win-title-in {
  0% {
    transform: translateY(-80vh) scale(0.5);
    opacity: 0;
  }
  18% { opacity: 1; }
  38% {
    transform: translateY(0) scale(1.08);
  }
  48% {
    transform: translateY(-40rpx) scale(1.02);
  }
  58% {
    transform: translateY(0) scale(1);
  }
  100% {
    transform: translateY(0) scale(1);
    opacity: 1;
  }
}

@keyframes win-sub-in {
  0% { opacity: 0; transform: translateY(20rpx); }
  30% { opacity: 1; transform: translateY(0); }
  100% { opacity: 0.9; }
}

.fx-particle-win {
  position: absolute;
  width: var(--size);
  height: var(--size);
  border-radius: 50%;
  background: #fbbf24;
  box-shadow: 0 0 16rpx #f97316;
  opacity: 0;
  animation: particle-rise 2s ease-out calc(0.4s + var(--delay)) infinite;
}

@keyframes particle-rise {
  0% { transform: translateY(0) scale(1); opacity: 0; }
  15% { opacity: 1; }
  100% { transform: translateY(-400rpx) scale(0.2); opacity: 0; }
}

/* ========== 失败 ========== */
.fx-lose {
  flex-direction: column;
}

.fx-lose-vignette {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at center, transparent 20%, rgba(15, 23, 42, 0.85) 100%);
  animation: lose-vignette-in 4s ease-out forwards;
}

@keyframes lose-vignette-in {
  0% { opacity: 0; }
  30% { opacity: 1; }
  100% { opacity: 1; }
}

.fx-lose-rain {
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    180deg,
    transparent 0,
    transparent 40rpx,
    rgba(148, 163, 184, 0.06) 40rpx,
    rgba(148, 163, 184, 0.06) 42rpx
  );
  animation: lose-rain-fall 0.8s linear infinite;
  opacity: 0.5;
}

@keyframes lose-rain-fall {
  100% { background-position: 0 80rpx; }
}

.fx-title-lose .fx-title-main {
  color: #cbd5e1;
  text-shadow:
    0 0 24rpx rgba(100, 116, 139, 0.8),
    0 6rpx 0 #334155,
    0 12rpx 40rpx rgba(0, 0, 0, 0.7);
  animation: lose-title-in 4s cubic-bezier(0.25, 0.85, 0.35, 1) forwards;
}

.fx-title-lose .fx-title-sub {
  color: #94a3b8;
  animation: lose-sub-in 4s ease-out 0.25s forwards;
  opacity: 0;
}

@keyframes lose-title-in {
  0% {
    transform: translateY(-70vh) scale(0.6);
    opacity: 0;
  }
  15% { opacity: 1; }
  32% {
    transform: translateY(0) scale(1);
  }
  36% {
    transform: translateY(8rpx) scale(0.98);
  }
  40% {
    transform: translateY(0) scale(1);
  }
  44% {
    transform: translateX(-12rpx);
  }
  48% {
    transform: translateX(12rpx);
  }
  52% {
    transform: translateX(-8rpx);
  }
  56% {
    transform: translateX(0);
  }
  100% {
    transform: translateY(0) scale(1);
    opacity: 1;
  }
}

@keyframes lose-sub-in {
  0% { opacity: 0; }
  35% { opacity: 1; }
  100% { opacity: 0.85; }
}

.fx-particle-lose {
  position: absolute;
  top: -20rpx;
  width: 4rpx;
  height: 48rpx;
  background: linear-gradient(180deg, rgba(148, 163, 184, 0.6), transparent);
  opacity: 0;
  animation: lose-drop 1.2s linear calc(var(--delay)) infinite;
}

@keyframes lose-drop {
  0% { transform: translateY(-20rpx); opacity: 0; }
  10% { opacity: 0.7; }
  100% { transform: translateY(110vh); opacity: 0; }
}

/* ========== 平局 ========== */
.fx-draw {
  flex-direction: column;
}

.fx-draw-ring {
  position: absolute;
  width: 700rpx;
  height: 700rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(226, 232, 240, 0.35);
  box-shadow: 0 0 80rpx rgba(226, 232, 240, 0.25);
  animation: draw-ring-in 4s ease-out forwards;
}

@keyframes draw-ring-in {
  0% { transform: scale(0); opacity: 0; }
  30% { transform: scale(1); opacity: 1; }
  100% { transform: scale(1.05); opacity: 0.6; }
}

.fx-title-draw .fx-title-main {
  color: #f1f5f9;
  text-shadow:
    0 0 48rpx rgba(226, 232, 240, 0.9),
    0 8rpx 0 #64748b;
  animation: draw-title-in 4s cubic-bezier(0.25, 0.9, 0.35, 1) forwards;
}

.fx-title-draw .fx-title-sub {
  color: #cbd5e1;
  animation: draw-sub-in 4s ease-out 0.2s forwards;
  opacity: 0;
}

@keyframes draw-title-in {
  0% {
    transform: translateY(-90vh) scale(1.1);
    opacity: 0;
  }
  28% { opacity: 1; transform: translateY(0) scale(1); }
  36% { transform: translateY(-36rpx); }
  44% { transform: translateY(0); }
  52% { transform: translateY(-36rpx); }
  60% { transform: translateY(0); }
  68% { transform: translateY(-24rpx); }
  76% { transform: translateY(0); }
  100% { opacity: 1; }
}

@keyframes draw-sub-in {
  0% { opacity: 0; }
  40% { opacity: 1; }
  100% { opacity: 0.9; }
}

/* ========== 升段（保留） ========== */
.fx-tier { flex-direction: column; }

.fx-char-tier {
  font-size: 45rpx;
  letter-spacing: 6rpx;
  color: #D4AF37;
  margin-bottom: 48rpx;
  animation: char-pop 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

.fx-stage {
  position: relative;
  width: 520rpx;
  height: 520rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tier-stage { width: 560rpx; height: 560rpx; }

.tier-img {
  position: absolute;
  width: 360rpx;
  height: 360rpx;
  left: 50%;
  top: 50%;
  margin-left: -180rpx;
  margin-top: -180rpx;
}

.tier-old { animation: tier-old-in 0.6s ease-out forwards; z-index: 2; }

@keyframes tier-old-in {
  0% { transform: scale(0.5); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.tier-old-break { animation: tier-old-break 0.5s ease-in forwards; }

@keyframes tier-old-break {
  100% { transform: scale(0.6) rotate(-12deg); opacity: 0; filter: blur(4rpx); }
}

.tier-new-hide {
  opacity: 0;
  transform: translateY(-400rpx) scale(0.5);
}

.tier-new-drop {
  z-index: 5;
  animation: tier-new-smash 0.65s cubic-bezier(0.34, 1.2, 0.64, 1) forwards;
}

@keyframes tier-new-smash {
  0% { transform: translateY(-420rpx) scale(0.7); opacity: 0; }
  100% { transform: translateY(0) scale(1); opacity: 1; }
}

.tier-smash-flash {
  position: absolute;
  width: 400rpx;
  height: 400rpx;
  left: 50%;
  top: 50%;
  margin: -200rpx 0 0 -200rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(245, 230, 163, 0.9), transparent 70%);
  animation: smash-flash 0.4s ease-out forwards;
  z-index: 4;
}

@keyframes smash-flash {
  100% { transform: scale(1.8); opacity: 0; }
}

.tier-crack {
  position: absolute;
  width: 300rpx;
  height: 6rpx;
  left: 50%;
  top: 50%;
  margin-left: -150rpx;
  margin-top: -3rpx;
  background: linear-gradient(90deg, transparent, #fff, #D4AF37, transparent);
  animation: tier-crack 0.35s ease-out forwards;
  z-index: 3;
}

@keyframes tier-crack {
  100% { transform: scaleX(1.2); opacity: 0; }
}

.tier-fragment {
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  background: rgba(212, 175, 55, 0.6);
  opacity: 0;
  animation: tier-frag 0.6s ease-out var(--delay) forwards;
}

@keyframes tier-frag {
  100% { transform: rotate(var(--rot)) translate(160rpx, 0); opacity: 0; }
}

@keyframes char-pop {
  0% { transform: scale(0.3); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
