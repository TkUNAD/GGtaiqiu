<view class="fx-mask" wx:if="{{visible}}" catchtouchmove="noop">
  <!-- 胜利 -->
  <view class="fx-scene fx-win" wx:if="{{fxKind === 'win'}}">
    <view class="fx-win-rays"></view>
    <view class="fx-win-burst"></view>
    <view
      class="fx-particle fx-particle-win"
      wx:for="{{particles}}"
      wx:key="id"
      style="left: {{item.left}}%; top: {{item.top}}%; --delay: {{item.delay}}s; --size: {{item.size}}rpx;"
    ></view>
    <view class="fx-title-wrap fx-title-win">
      <text class="fx-title-main">胜利</text>
      <text class="fx-title-sub">VICTORY</text>
    </view>
  </view>

  <!-- 失败 -->
  <view class="fx-scene fx-lose" wx:if="{{fxKind === 'lose'}}">
    <view class="fx-lose-vignette"></view>
    <view class="fx-lose-rain"></view>
    <view
      class="fx-particle fx-particle-lose"
      wx:for="{{particles}}"
      wx:key="id"
      style="left: {{item.left}}%; --delay: {{item.delay}}s;"
    ></view>
    <view class="fx-title-wrap fx-title-lose">
      <text class="fx-title-main">失败</text>
      <text class="fx-title-sub">DEFEAT</text>
    </view>
  </view>

  <!-- 平局 -->
  <view class="fx-scene fx-draw" wx:if="{{fxKind === 'draw'}}">
    <view class="fx-draw-ring"></view>
    <view class="fx-title-wrap fx-title-draw">
      <text class="fx-title-main">平局</text>
      <text class="fx-title-sub">DRAW</text>
    </view>
  </view>

  <!-- 升段 -->
  <view class="fx-scene fx-tier" wx:if="{{fxKind === 'tierUp'}}">
    <text class="fx-char-tier">段位晋升</text>
    <view class="fx-stage tier-stage">
      <image
        class="tier-img tier-old {{tierPhase === 'smash' ? 'tier-old-break' : ''}}"
        src="{{oldSrc}}"
        mode="aspectFit"
      />
      <view class="tier-smash-flash" wx:if="{{tierPhase === 'smash'}}"></view>
      <view class="tier-crack" wx:if="{{tierPhase === 'smash'}}"></view>
      <image
        class="tier-img tier-new {{tierPhase === 'smash' ? 'tier-new-drop' : 'tier-new-hide'}}"
        src="{{newSrc}}"
        mode="aspectFit"
      />
      <view
        class="tier-fragment"
        wx:if="{{tierPhase === 'smash'}}"
        wx:for="{{shards}}"
        wx:key="id"
        style="--rot: {{item.rot}}deg; --delay: {{item.delay}}s;"
      ></view>
    </view>
  </view>
</view>
