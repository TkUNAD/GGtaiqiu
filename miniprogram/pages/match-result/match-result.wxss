.container { padding: 24rpx; padding-bottom: 60rpx; }
.header { text-align: center; }
.title { font-size: 41rpx; color: #D4AF37; font-weight: bold; }
.sub { display: block; color: #c9cdd8; margin-top: 12rpx; }
.invalid, .warn { display: block; color: #f0a8a8; margin-top: 8rpx; font-size: 25rpx; }
.score-card { margin-top: 24rpx; }
.player {
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  background: linear-gradient(145deg, rgba(212, 175, 55, 0.1), rgba(10, 15, 26, 0.5));
  margin: 12rpx 0;
  border: 1rpx solid rgba(212, 175, 55, 0.2);
}
.player.winner {
  border: 2rpx solid #D4AF37;
  background: linear-gradient(145deg, rgba(212, 175, 55, 0.3), rgba(10, 15, 26, 0.6));
  box-shadow: 0 0 20rpx rgba(212, 175, 55, 0.2);
}
.name { display: block; font-size: 33rpx; font-weight: bold; color: #f5f0e1; }
.frames { display: block; font-size: 49rpx; color: #D4AF37; margin: 12rpx 0; }
.delta { display: block; font-size: 29rpx; margin: 8rpx 0; }
.plus { color: #86efac; }
.minus { color: #f0a8a8; }
.now { display: block; font-size: 25rpx; color: #8b92a8; }
.stats {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-top: 16rpx;
  font-size: 27rpx;
  color: #c9cdd8;
}
.vs { text-align: center; color: #D4AF37; font-size: 29rpx; margin: 8rpx 0; }
