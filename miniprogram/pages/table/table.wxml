<view class="container">

  <view class="card" wx:if="{{table}}">

    <view class="title">{{table.name}}</view>

    <text>状态: {{table.current_match_id ? '对局进行中' : (table.players_ready && table.opened ? '选手已到齐(可开始对局)' : (table.opened ? '已开台，等待选手' : '已关台，请重新扫码签到'))}}</text>

  </view>



  <view class="card" wx:if="{{!match || match.status !== 'playing'}}">

    <view class="title">扫码签到</view>

    <text class="hint">请两名选手均扫描本桌二维码，到场后可开始对战</text>

    <view class="waiting-box">

      <text class="waiting-count">已到场 {{table.waiting_count || 0}} / 2</text>

      <view class="waiting-item" wx:for="{{table.waiting_players}}" wx:key="user_id">

        <text>{{item.nickname}}{{item.is_me ? '（我）' : ''}}</text>

      </view>

      <text wx:if="{{!table.waiting_count}}" class="wait-tip">等待选手扫码…</text>

    </view>



    <block wx:if="{{table.waiting_count >= 1 || table.i_am_waiting}}">

      <picker mode="selector" range="{{['抢5','抢7']}}" value="{{racePickerIndex}}" bindchange="onRaceChange">

        <view class="picker">局数: 抢{{raceTo}}</view>

      </picker>

      <text class="hint sync-race" wx:if="{{table.race_picker}}">{{table.race_picker.nickname}} 选择了抢{{table.race_to}}（双方已同步）</text>

      <text class="hint" wx:if="{{table.can_start}}">系统将按天梯规则自动判定排位赛或休闲局</text>

    </block>

    <view class="btn-primary" wx:if="{{table.can_start}}" bindtap="startMatch">开始对战</view>

    <view wx:elif="{{table.waiting_count < 2}}" class="btn-disabled">等待另一名选手扫码</view>

    <view class="btn-secondary" bindtap="refreshMatch">刷新状态</view>

  </view>



  <view class="card" wx:if="{{match && match.status === 'playing'}}">

    <view class="title">进行中 - 抢{{match.race_to}}</view>

    <view class="score-board">

      <text class="big">{{match.score1}}</text>

      <text class="vs">VS</text>

      <text class="big">{{match.score2}}</text>

    </view>

    <view class="names">

      <text>{{match.p1.nickname}}</text>

      <text>{{match.p2.nickname}}</text>

    </view>

    <view class="type-tag">{{match.match_type === 'ranked' ? '排位赛' : '休闲局'}}</view>



    <view class="bonus-section bonus-section-center">

      <text class="bonus-title">炸清/接清（需双方确认后加分）</text>

      <view class="bonus-row">

        <view class="bonus-btn" bindtap="requestBonus" data-type="break_run">申报炸清+20</view>

        <view class="bonus-btn" bindtap="requestBonus" data-type="clearance">申报接清+15</view>

      </view>

      <view class="pending-list" wx:if="{{pendingBonuses.length}}">

        <view class="pending-item" wx:for="{{pendingBonuses}}" wx:key="id">

          <text>{{item.label}}（已确认{{item.confirmed_count}}/2）</text>

          <button size="mini" bindtap="confirmBonus" data-id="{{item.id}}">确认</button>

        </view>

      </view>

    </view>



    <view class="btn-row">

      <view class="btn-win" bindtap="onWin">本局胜利</view>

      <view class="btn-lose" bindtap="onLose">本局失败</view>

    </view>

    <text class="cooldown" wx:if="{{cooldown > 0}}">按钮冷却: {{cooldown}}秒</text>



    <view class="btn-secondary" bindtap="endEarly">提前结束(积分减半)</view>

    <view class="btn-secondary" bindtap="refreshMatch">刷新比分</view>

    <view class="bonus-summary-bar">

      <text class="bonus-summary-title">本场炸清 / 接清加分</text>

      <view class="bonus-summary-row">

        <view class="bonus-summary-col">

          <text class="bonus-summary-name">{{match.p1.nickname}}</text>

          <view class="bonus-summary-tags">

            <text class="bonus-tag break">炸清 +{{match.p1_break_pts || 0}}</text>

            <text class="bonus-tag clear">接清 +{{match.p1_clear_pts || 0}}</text>

          </view>

        </view>

        <view class="bonus-summary-col">

          <text class="bonus-summary-name">{{match.p2.nickname}}</text>

          <view class="bonus-summary-tags">

            <text class="bonus-tag break">炸清 +{{match.p2_break_pts || 0}}</text>

            <text class="bonus-tag clear">接清 +{{match.p2_clear_pts || 0}}</text>

          </view>

        </view>

      </view>

    </view>

  </view>

  <view class="card" wx:if="{{loadError}}">
    <text class="hint" style="color:#F9A8D4">{{loadError}}</text>
    <view class="btn-secondary" bindtap="refreshMatch">重试</view>
  </view>

  <view class="card" wx:if="{{pageReady && !table && !loadError}}">
    <text class="hint">加载桌台信息中…</text>
    <view class="btn-secondary" bindtap="refreshMatch">刷新</view>
  </view>

  <!-- 对手炸清/接清确认卡片 -->
  <view class="bonus-overlay" wx:if="{{opponentBonusCard}}" catchtouchmove="noop">
    <view class="bonus-card">
      <view class="bonus-card-title">炸清 / 接清申报</view>
      <text class="bonus-card-desc">{{opponentBonusCard.claimer_name}} 申报了</text>
      <text class="bonus-card-type">{{opponentBonusCard.typeLabel}}</text>
      <text class="bonus-card-hint">是否同意为该申报加分？</text>
      <view class="bonus-card-actions">
        <view class="bonus-card-btn reject" bindtap="onRejectOpponentCard">拒绝</view>
        <view class="bonus-card-btn confirm" bindtap="onConfirmOpponentCard">确认</view>
      </view>
    </view>
  </view>

</view>

