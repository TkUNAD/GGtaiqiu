<view class="table-page">
  <block wx:if="{{table}}">

  <!-- ========== 开台前：桌号 + 局数 + VS 对阵 + 开始 ========== -->
  <view class="lobby-shell" wx:if="{{!match || match.status !== 'playing'}}">
    <view class="lobby-top">
      <text class="lobby-table-name">{{table.name}}</text>
      <text class="lobby-table-sub" wx:if="{{table.opened}}">已开台 · 到场 {{table.waiting_count || 0}}/2</text>
      <text class="lobby-table-sub" wx:else>扫码签到 · 到场 {{table.waiting_count || 0}}/2</text>
    </view>

    <view class="race-panel float-surface" wx:if="{{table.waiting_count >= 1 || table.i_am_waiting}}">
      <text class="race-panel-label">选择对局数</text>
      <view class="race-picker" bindtap="openRacePicker">
        <text class="race-picker-text">抢{{raceTo}}</text>
        <text class="race-picker-arrow">{{racePickerOpen ? '▲' : '▼'}}</text>
      </view>
      <view class="race-dropdown-mask" wx:if="{{racePickerOpen}}" bindtap="closeRacePicker">
        <view class="race-dropdown" catchtap="noop">
          <view
            wx:for="{{raceLabels}}"
            wx:key="*this"
            class="race-dropdown-item {{racePickerIndex === index ? 'race-dropdown-item-active' : ''}}"
            bindtap="onRaceOptionTap"
            data-index="{{index}}"
          >{{item}}</view>
        </view>
      </view>
      <text class="race-sync" wx:if="{{table.race_picker}}">{{table.race_picker.nickname}} 选择了抢{{table.race_to}}（双方已同步）</text>
    </view>

    <view class="vs-arena float-surface">
      <view class="fighter-slot">
        <image
          class="fighter-avatar"
          src="{{lobbyP1.avatar || '/assets/default-avatar.png'}}"
          mode="aspectFill"
          binderror="onLobbyAvatarError"
          data-slot="lobbyP1"
        />
        <text class="fighter-name">{{lobbyP1.nickname}}</text>
        <view class="fighter-tier">
          <image class="tier-img tier-img-sm" src="{{lobbyP1.tierImage}}" mode="aspectFit" />
          <text class="fighter-tier-text">{{lobbyP1.tierName}}</text>
        </view>
      </view>

      <view class="vs-epic">
        <view class="vs-epic-ring vs-epic-ring-1"></view>
        <view class="vs-epic-ring vs-epic-ring-2"></view>
        <view class="vs-epic-flash vs-epic-flash-l"></view>
        <view class="vs-epic-flash vs-epic-flash-r"></view>
        <view class="vs-epic-strike"></view>
        <text class="vs-epic-text">VS</text>
      </view>

      <view class="fighter-slot">
        <image
          class="fighter-avatar"
          src="{{lobbyP2.avatar || '/assets/default-avatar.png'}}"
          mode="aspectFill"
          binderror="onLobbyAvatarError"
          data-slot="lobbyP2"
        />
        <text class="fighter-name">{{lobbyP2.nickname}}</text>
        <view class="fighter-tier">
          <image class="tier-img tier-img-sm" src="{{lobbyP2.tierImage}}" mode="aspectFit" />
          <text class="fighter-tier-text">{{lobbyP2.tierName}}</text>
        </view>
      </view>
    </view>

    <view class="lobby-foot">
      <text class="lobby-hint" wx:if="{{table.can_start}}">两名选手已到齐，系统将按天梯规则判定排位赛或休闲局</text>
      <text class="lobby-hint" wx:elif="{{table.waiting_count < 2}}">请两名选手扫描本桌二维码到场</text>
      <view class="btn-start-battle" wx:if="{{table.can_start}}" bindtap="startMatch">对战开始</view>
      <view class="btn-start-disabled" wx:elif="{{table.waiting_count < 2}}">等待另一名选手扫码</view>
      <view class="btn-refresh-lite" bindtap="refreshMatch">刷新状态</view>
    </view>
  </view>

  <!-- ========== 对局进行中 ========== -->
  <view class="play-shell" wx:if="{{match && match.status === 'playing'}}">
    <view class="play-head float-surface">
      <text class="play-race">抢{{match.race_to}}</text>
      <text class="play-type">{{match.match_type === 'ranked' ? '排位赛' : '休闲局'}}</text>
      <text class="play-review-hint" wx:if="{{match.review_notice}}">{{match.review_notice}}</text>
    </view>

    <view class="play-scoreboard float-surface">
      <view class="play-side">
        <text class="play-score-num">{{match.score1}}</text>
        <text class="play-side-name">{{match.p1.nickname}}</text>
      </view>
      <view class="play-vs-core">
        <view class="play-vs-glow"></view>
        <text class="play-vs-text">VS</text>
      </view>
      <view class="play-side">
        <text class="play-score-num">{{match.score2}}</text>
        <text class="play-side-name">{{match.p2.nickname}}</text>
      </view>
    </view>

    <view class="play-fighters float-surface">
      <view class="play-fighter">
        <image
          class="play-avatar"
          src="{{match.p1.avatarUrl || '/assets/default-avatar.png'}}"
          mode="aspectFill"
          binderror="onPlayAvatarError"
          data-side="p1"
        />
        <image class="tier-img tier-img-sm" src="{{match.p1.tierImage}}" mode="aspectFit" />
        <text class="play-tier">{{match.p1.tierName}}</text>
      </view>
      <view class="play-fighter">
        <image
          class="play-avatar"
          src="{{match.p2.avatarUrl || '/assets/default-avatar.png'}}"
          mode="aspectFill"
          binderror="onPlayAvatarError"
          data-side="p2"
        />
        <image class="tier-img tier-img-sm" src="{{match.p2.tierImage}}" mode="aspectFit" />
        <text class="play-tier">{{match.p2.tierName}}</text>
      </view>
    </view>

    <view class="bonus-section bonus-section-center float-surface">
      <text class="bonus-title">炸清/接清（对方确认后加分，申报方胜1局）</text>
      <view class="bonus-row">
        <view class="bonus-btn {{cooldown > 0 ? 'btn-action-disabled' : ''}}" bindtap="requestBonus" data-type="break_run">申报炸清+20</view>
        <view class="bonus-btn {{cooldown > 0 ? 'btn-action-disabled' : ''}}" bindtap="requestBonus" data-type="clearance">申报接清+15</view>
      </view>
      <view class="pending-list" wx:if="{{pendingBonuses.length}}">
        <view class="pending-item" wx:for="{{pendingBonuses}}" wx:key="id">
          <text>{{item.label}}（待您确认）</text>
          <button size="mini" bindtap="confirmBonus" data-id="{{item.id}}">同意</button>
        </view>
      </view>
    </view>

    <view class="btn-row">
      <view class="btn-win {{cooldown > 0 ? 'btn-action-disabled' : ''}}" bindtap="onWin">本局胜利</view>
      <view class="btn-lose {{cooldown > 0 ? 'btn-action-disabled' : ''}}" bindtap="onLose">本局失败</view>
    </view>
    <text class="cooldown" wx:if="{{cooldown > 0}}">炸清/接清/胜局/负局 操作冷却: {{cooldown}}秒</text>

    <view class="btn-secondary" bindtap="endEarly">提前结束(积分减半)</view>
    <view class="btn-secondary" bindtap="refreshMatch">刷新比分</view>

    <view class="idle-mask" wx:if="{{idleUi.active}}">
      <view class="idle-dialog">
        <view class="idle-title" wx:if="{{idleUi.phase === 'prompt'}}">长时间无操作提醒</view>
        <view class="idle-title" wx:else>结束比赛确认</view>
        <text class="idle-desc" wx:if="{{idleUi.phase === 'prompt'}}">
          双方已超过10分钟未操作。请在 {{idleUi.seconds_left}} 秒内选择，超时将自动结束并按当前比分结算。
        </text>
        <text class="idle-desc" wx:elif="{{idleUi.end_requested_by_me}}">
          已向对方发起结束请求，等待对方确认（{{idleUi.end_seconds_left}} 秒）…
        </text>
        <text class="idle-desc" wx:elif="{{idleUi.need_my_end_response}}">
          对方请求结束比赛，是否同意？{{idleUi.end_seconds_left}} 秒内未操作将自动结束。
        </text>
        <text class="idle-desc" wx:else>处理中…</text>
        <view class="idle-status" wx:if="{{idleUi.phase === 'prompt'}}">
          <text>您：{{idleUi.my_continue_confirmed ? '已确认继续' : '未确认'}}</text>
          <text>对方：{{idleUi.opponent_continue_confirmed ? '已确认继续' : '未确认'}}</text>
        </view>
        <view class="idle-btns" wx:if="{{idleUi.phase === 'prompt'}}">
          <button class="idle-btn primary" bindtap="onIdleContinue" disabled="{{!idleUi.need_my_continue}}">
            {{idleUi.my_continue_confirmed ? '已确认继续' : '继续比赛'}}
          </button>
          <button class="idle-btn danger" bindtap="onIdleEnd">结束比赛</button>
        </view>
        <view class="idle-btns" wx:elif="{{idleUi.need_my_end_response}}">
          <button class="idle-btn primary" bindtap="onIdleAgreeEnd">同意结束</button>
          <button class="idle-btn" bindtap="onIdleRejectEnd">不同意，继续比赛</button>
        </view>
      </view>
    </view>

    <view class="bonus-summary-bar">
      <text class="bonus-summary-title">本场炸清 / 接清加分</text>
      <view class="bonus-summary-row">
        <view class="bonus-summary-col">
          <text class="bonus-summary-name">{{match.p1.nickname}}</text>
          <view class="bonus-summary-tags">
            <text class="bonus-tag break">炸清 +{{match.p1_break_pts || 0}}</text>
            <text class="bonus-tag clear">接清 +{{match.p1_clear_pts || 0}}</text>
          </view>
        </view>
        <view class="bonus-summary-col">
          <text class="bonus-summary-name">{{match.p2.nickname}}</text>
          <view class="bonus-summary-tags">
            <text class="bonus-tag break">炸清 +{{match.p2_break_pts || 0}}</text>
            <text class="bonus-tag clear">接清 +{{match.p2_clear_pts || 0}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
  </block>

  <view class="card" wx:if="{{loadError}}">
    <text class="hint" style="color:#F9A8D4">{{loadError}}</text>
    <view class="btn-secondary" bindtap="refreshMatch">重试</view>
  </view>

  <view class="card" wx:if="{{pageReady && !table && !loadError}}">
    <text class="hint">加载桌台信息中…</text>
    <view class="btn-secondary" bindtap="refreshMatch">刷新</view>
  </view>

  <view class="bonus-overlay" wx:if="{{opponentBonusCard}}" catchtouchmove="noop">
    <view class="bonus-card">
      <view class="bonus-card-title">炸清 / 接清申报</view>
      <text class="bonus-card-desc">{{opponentBonusCard.claimer_name}} 申报了</text>
      <text class="bonus-card-type">{{opponentBonusCard.typeLabel}}</text>
      <text class="bonus-card-hint">是否同意？未达审核次数则加分并胜1局；达次数则仅记录待审核，比分可继续增加</text>
      <view class="bonus-card-actions">
        <view class="bonus-card-btn reject" bindtap="onRejectOpponentCard">拒绝</view>
        <view class="bonus-card-btn confirm" bindtap="onConfirmOpponentCard">确认</view>
      </view>
    </view>
  </view>
</view>
