.picker { padding: 20rpx; background: rgba(0, 0, 0, 0.25); margin: 12rpx 0; border-radius: 8rpx; border: 1rpx solid rgba(167, 139, 250, 0.3); }
.score-board { display: flex; justify-content: center; align-items: center; padding: 40rpx; }
.big { font-size: 80rpx; color: #E9D5FF; font-weight: bold; line-height: 1.1; }
.vs { margin: 0 40rpx; color: #93C5FD; }
.bonus-summary-bar {
  margin-top: 28rpx;
  padding: 24rpx 20rpx;
  background: rgba(0, 0, 0, 0.35);
  border-radius: 12rpx;
  border: 1rpx solid rgba(167, 139, 250, 0.35);
}
.bonus-summary-title {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #A5B4FC;
  margin-bottom: 16rpx;
}
.bonus-summary-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}
.bonus-summary-col {
  flex: 1;
  text-align: center;
}
.bonus-summary-name {
  display: block;
  font-size: 24rpx;
  color: #C4B5FD;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.bonus-summary-tags {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  align-items: center;
}
.bonus-tag {
  font-size: 26rpx;
  font-weight: bold;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}
.bonus-tag.break { color: #FCD34D; background: rgba(252, 211, 77, 0.12); }
.bonus-tag.clear { color: #93C5FD; background: rgba(147, 197, 253, 0.12); }
.sync-race { color: #FDE68A; margin-top: 8rpx; }
.type-tag { text-align: center; color: #C4B5FD; margin-bottom: 20rpx; }
.btn-row { display: flex; gap: 20rpx; }
.btn-win { flex: 1; background: linear-gradient(180deg, #7C3AED, #3B82F6); padding: 30rpx; text-align: center; border-radius: 12rpx; }
.btn-lose { flex: 1; background: linear-gradient(180deg, #BE185D, #9F1239); padding: 30rpx; text-align: center; border-radius: 12rpx; }
.cooldown { display: block; text-align: center; color: #F9A8D4; margin: 16rpx; }
.names { display: flex; justify-content: space-between; padding: 0 40rpx; color: #C4B5FD; font-size: 24rpx; }
.bonus-section { margin-top: 24rpx; padding-top: 16rpx; border-top: 1rpx dashed rgba(255,255,255,0.2); }
.bonus-section-center {
  margin: 32rpx 0;
  padding: 28rpx 16rpx;
  border-top: none;
  border-bottom: 1rpx dashed rgba(255,255,255,0.2);
  text-align: center;
}
.bonus-title { display: block; font-size: 26rpx; color: #A5B4FC; margin-bottom: 20rpx; }
.bonus-row {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  justify-content: space-between;
  align-items: stretch;
  gap: 20rpx;
  width: 100%;
  box-sizing: border-box;
}
.bonus-btn {
  flex: 1;
  background: linear-gradient(180deg, rgba(124, 58, 237, 0.85), rgba(59, 130, 246, 0.75));
  padding: 24rpx 16rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  border: 1rpx solid rgba(167, 139, 250, 0.5);
  text-align: center;
  box-sizing: border-box;
}
.pending-list { margin-top: 12rpx; }
.pending-item { display: flex; align-items: center; justify-content: space-between; background: rgba(0,0,0,0.25); padding: 16rpx; border-radius: 8rpx; margin-bottom: 8rpx; font-size: 26rpx; }
.pending-item .wait { color: #F9A8D4; font-size: 24rpx; }
.hint { display: block; font-size: 26rpx; color: #C4B5FD; margin-bottom: 16rpx; line-height: 1.5; }
.waiting-box { background: rgba(0,0,0,0.25); border-radius: 12rpx; padding: 20rpx; margin: 16rpx 0; }
.waiting-count { display: block; font-size: 32rpx; color: #E9D5FF; font-weight: bold; margin-bottom: 12rpx; }
.waiting-item { padding: 12rpx 0; font-size: 28rpx; color: #fff; border-bottom: 1rpx solid rgba(255,255,255,0.1); }
.wait-tip { font-size: 26rpx; color: #93C5FD; }
.btn-disabled { background: rgba(100,100,100,0.5); padding: 28rpx; text-align: center; border-radius: 12rpx; margin: 16rpx 0; color: #9CA3AF; font-size: 28rpx; }

.bonus-overlay {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(0, 0, 0, 0.65);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}
.bonus-card {
  width: 100%;
  max-width: 620rpx;
  background: linear-gradient(180deg, #1e1b4b, #312e81);
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  border: 2rpx solid rgba(167, 139, 250, 0.5);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.4);
  text-align: center;
}
.bonus-card-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #E9D5FF;
  margin-bottom: 28rpx;
}
.bonus-card-desc {
  display: block;
  font-size: 28rpx;
  color: #C4B5FD;
}
.bonus-card-type {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #FDE68A;
  margin: 16rpx 0 24rpx;
}
.bonus-card-hint {
  display: block;
  font-size: 26rpx;
  color: #A5B4FC;
  margin-bottom: 40rpx;
}
.bonus-card-actions {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  gap: 24rpx;
}
.bonus-card-btn {
  flex: 1;
  padding: 28rpx 16rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  text-align: center;
}
.bonus-card-btn.reject {
  background: rgba(100, 100, 100, 0.5);
  color: #E5E7EB;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}
.bonus-card-btn.confirm {
  background: linear-gradient(180deg, #7C3AED, #3B82F6);
  color: #fff;
}
