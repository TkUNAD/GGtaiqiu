.login-hint { text-align: center; color: #8b92a8; }
.login-hint .btn-primary { margin-top: 24rpx; }
.rules-hint { font-size: 27rpx; color: #e8eaf0; line-height: 1.5; }
.rules-sub { display: block; margin-top: 12rpx; font-size: 25rpx; color: #8b92a8; }

.pname { font-size: 33rpx; font-weight: bold; color: #f5f0e1; }
.ptype { font-size: 25rpx; color: #8b92a8; margin: 8rpx 0; }
.prow { display: flex; align-items: center; justify-content: space-between; }
.points { color: #D4AF37; font-weight: 600; }
.stock { font-size: 25rpx; color: #c9cdd8; }
.btn-small {
  background: linear-gradient(135deg, #f5e6b8, #D4AF37);
  color: #0A0F1A;
  padding: 12rpx 24rpx;
  border-radius: 14rpx;
  font-size: 27rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 14rpx rgba(212, 175, 55, 0.28);
}
.record { display: flex; flex-direction: column; gap: 8rpx; }
.status { color: #86efac; }
.time { font-size: 23rpx; color: #8b92a8; }
