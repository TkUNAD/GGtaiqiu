.item { margin-bottom: 20rpx; }
.row-top, .row-mid, .row-bot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 26rpx;
  margin-bottom: 8rpx;
}
.type { color: #C4B5FD; }
.status { color: #93C5FD; font-size: 24rpx; }
.score { font-weight: bold; font-size: 30rpx; }
.result.win { color: #93C5FD; }
.result.lose { color: #F472B6; }
.plus { color: #93C5FD; }
.minus { color: #F472B6; }
.time { font-size: 22rpx; color: #A5B4FC; width: 100%; text-align: right; }
.hint, .empty, .err { text-align: center; color: #C4B5FD; }
