.tabs { display: flex; overflow: hidden; }
.tab {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  font-size: 29rpx;
  color: #8b92a8;
  border-radius: 14rpx;
}
.tab.active {
  background: linear-gradient(135deg, rgba(245, 230, 163, 0.28), rgba(212, 175, 55, 0.18));
  color: #D4AF37;
  font-weight: bold;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.float-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.rank-num {
  width: 56rpx;
  text-align: center;
  font-size: 29rpx;
  color: #8b92a8;
  font-weight: bold;
}
.rank-num.num-first {
  font-size: 49rpx;
  color: #D4AF37;
  width: 64rpx;
  text-shadow: 0 0 20rpx rgba(212, 175, 55, 0.45);
}
.avatar-sm {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(212, 175, 55, 0.38);
}
.info { flex: 1; min-width: 0; }
.name-line { display: flex; align-items: center; gap: 10rpx; }
.name { font-size: 31rpx; font-weight: bold; color: #f5f0e1; }
.tier { display: block; font-size: 25rpx; color: #c9cdd8; margin-top: 4rpx; }
.sub-rank { display: block; font-size: 23rpx; color: #8b92a8; margin-top: 4rpx; }
.rank-icon { font-size: 37rpx; }
.empty { text-align: center; color: #8b92a8; padding: 48rpx; margin: 24rpx 28rpx; }

.player-mask {
  position: fixed;
  left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(10, 15, 26, 0.85);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}
.player-panel { width: 100%; margin: 0 !important; text-align: center; }
.player-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(212, 175, 55, 0.5);
  margin-bottom: 16rpx;
}
.player-name { font-size: 35rpx; font-weight: bold; color: #f5f0e1; }
.player-tier-text { color: #D4AF37; font-size: 27rpx; }
.player-stats {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  font-size: 27rpx;
  color: #c9cdd8;
  margin: 20rpx 0 24rpx;
}
