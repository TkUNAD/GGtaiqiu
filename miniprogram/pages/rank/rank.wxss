.header { text-align: center; font-size: 40rpx; color: #C4B5FD; padding: 30rpx; text-shadow: 0 2rpx 8rpx rgba(107, 33, 168, 0.5); }
.rank-item {
  display: flex;
  align-items: center;
  margin: 16rpx 24rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  border: 1rpx solid rgba(147, 197, 253, 0.2);
}
.rank-item.top { border-left: 6rpx solid #E9D5FF; background: linear-gradient(90deg, rgba(147, 51, 234, 0.25), transparent); }
.rank-num { width: 60rpx; font-size: 36rpx; color: #E9D5FF; font-weight: bold; text-align: center; }
.rank-icon { width: 60rpx; font-size: 40rpx; text-align: center; line-height: 1; }
.info { flex: 1; }
.name { display: block; font-size: 30rpx; }
.tier { font-size: 24rpx; color: #93C5FD; }
.score { color: #BFDBFE; font-size: 32rpx; font-weight: bold; }
.empty { text-align: center; padding: 80rpx; color: #A5B4FC; }
