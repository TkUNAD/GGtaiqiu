.agreement-page {
  padding: 32rpx;
  padding-bottom: 64rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: #0A0F1A;
}

.agreement-head {
  margin-bottom: 40rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(212, 175, 55, 0.2);
}

.agreement-title {
  display: block;
  font-size: 37rpx;
  font-weight: bold;
  color: #f5f0e1;
  margin-bottom: 12rpx;
}

.agreement-update {
  font-size: 23rpx;
  color: #8b92a8;
}

.agreement-section {
  margin-bottom: 36rpx;
}

.section-heading {
  display: block;
  font-size: 29rpx;
  font-weight: bold;
  color: #D4AF37;
  margin-bottom: 16rpx;
}

.section-body {
  display: block;
  font-size: 27rpx;
  line-height: 1.75;
  color: #c9cdd8;
}
