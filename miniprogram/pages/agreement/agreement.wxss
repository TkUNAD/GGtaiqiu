.agreement-page {
  padding-bottom: 64rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.agreement-head {
  margin-top: 24rpx;
}

.agreement-title {
  display: block;
  font-size: 37rpx;
  font-weight: bold;
  color: #f5f0e1;
  margin-bottom: 12rpx;
}

.agreement-update {
  font-size: 23rpx;
  color: #8b92a8;
}

.agreement-section {
  margin-bottom: 36rpx;
}

.section-heading {
  display: block;
  font-size: 29rpx;
  font-weight: bold;
  color: #D4AF37;
  margin-bottom: 16rpx;
}

.section-body {
  display: block;
  font-size: 27rpx;
  line-height: 1.75;
  color: #c9cdd8;
}
