<view class="container">
  <view wx:if="{{loading}}" class="hint card">加载中…</view>
  <view wx:elif="{{loadError}}" class="card">
    <text class="err">{{loadError}}</text>
    <view class="btn-primary" bindtap="load">重试</view>
  </view>
  <view wx:elif="{{!list.length}}" class="empty card">暂无兑换记录</view>
  <view wx:else>
    <view class="card item" wx:for="{{list}}" wx:key="id">
      <view class="row-top">
        <text class="name">{{item.product_name}}</text>
        <text class="minus">-{{item.points}} 积分</text>
      </view>
      <text class="status">{{item.statusLabel}}</text>
      <text class="time">{{item.created_at_short}}</text>
    </view>
  </view>
</view>
