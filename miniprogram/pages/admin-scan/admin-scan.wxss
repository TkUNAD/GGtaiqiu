.scan-card { text-align: center; }
.scan-title { font-size: 34rpx; font-weight: bold; color: #f5f0e1; margin-bottom: 16rpx; }
.scan-desc { font-size: 26rpx; color: #8b92a8; line-height: 1.6; margin-bottom: 32rpx; }
.btn-scan { margin-top: 8rpx; }

.tip-card { margin-top: 8rpx; }
.tip-title { font-size: 28rpx; font-weight: bold; color: #D4AF37; margin-bottom: 12rpx; }
.tip-line { font-size: 24rpx; color: #8b92a8; line-height: 1.7; margin-bottom: 8rpx; }
.tip-title.link { color: #D4AF37; }
.link-nav { color: #D4AF37; text-decoration: underline; display: block; margin-top: 8rpx; }
.form-input {
  background: #12182a;
  border: 1rpx solid rgba(212, 175, 55, 0.2);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  color: #f5f0e1;
  font-size: 28rpx;
  margin-top: 16rpx;
}
