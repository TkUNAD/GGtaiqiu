.admin-navigator {
  display: block;
  box-sizing: border-box;
  text-decoration: none;
  color: inherit;
}
.admin-entry-hover {
  opacity: 0.88;
  transform: scale(0.99);
}
.admin-entry-card {
  border-color: rgba(212, 175, 55, 0.35);
  background: linear-gradient(145deg, rgba(212, 175, 55, 0.12) 0%, rgba(18, 24, 42, 0.95) 55%);
}
.admin-entry-card.admin-entry-active {
  border-color: rgba(212, 175, 55, 0.75);
  box-shadow: 0 4rpx 20rpx rgba(212, 175, 55, 0.2);
}
.console-switch-tip {
  margin: 8rpx 0 16rpx;
  padding: 16rpx 20rpx;
  font-size: 24rpx;
  color: #c4b5fd;
  background: rgba(91, 33, 182, 0.15);
  border-radius: 12rpx;
  border: 1rpx solid rgba(196, 181, 253, 0.25);
}
.admin-entry-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}
.admin-entry-active-tag {
  font-size: 20rpx;
  color: #1e1b4b;
  background: #c4b5fd;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}
.admin-entry-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.admin-entry-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #D4AF37;
}
.admin-entry-arrow {
  font-size: 40rpx;
  color: #D4AF37;
}
.super-setup-url {
  font-size: 22rpx;
  word-break: break-all;
  margin-top: 12rpx;
  color: #9ca3af;
}
.btn-copy-setup {
  margin-top: 16rpx;
}
.admin-entry-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8b92a8;
}
.profile-card { text-align: center; }
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin: 0 auto 16rpx;
  border: 4rpx solid rgba(212, 175, 55, 0.45);
  box-shadow: 0 8rpx 28rpx rgba(212, 175, 55, 0.18);
}
.avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    linear-gradient(145deg, rgba(212, 175, 55, 0.18) 0%, transparent 55%),
    linear-gradient(168deg, #2a3550 0%, #1a2236 100%);
}
.avatar-fallback-text {
  font-size: 52rpx;
  font-weight: 800;
  color: #D4AF37;
  line-height: 1;
}
.name { font-size: 37rpx; font-weight: bold; color: #f5f0e1; }
.tier { color: #D4AF37; }
.score { color: #D4AF37; font-size: 29rpx; margin-top: 8rpx; }

.stats-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.stat-item {
  width: calc(33.33% - 12rpx);
  box-sizing: border-box;
  padding: 20rpx 8rpx;
  text-align: center;
  border-radius: 18rpx;
  background:
    linear-gradient(145deg, rgba(212, 175, 55, 0.1) 0%, transparent 50%),
    linear-gradient(168deg, #181f32 0%, #12182a 100%);
  border: 1rpx solid rgba(212, 175, 55, 0.18);
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.25);
}
.stat-item.highlight {
  background:
    linear-gradient(145deg, rgba(212, 175, 55, 0.28) 0%, rgba(212, 175, 55, 0.08) 45%, transparent 55%),
    linear-gradient(168deg, #222b45 0%, #161f33 100%);
  border-color: rgba(212, 175, 55, 0.38);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3), 0 0 24rpx rgba(212, 175, 55, 0.08);
}
.stat-val { display: block; font-size: 33rpx; font-weight: bold; color: #D4AF37; }
.stat-label { display: block; font-size: 23rpx; color: #8b92a8; margin-top: 6rpx; }

.match-row, .log-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(212, 175, 55, 0.08);
  font-size: 27rpx;
}
.plus { color: #86efac; }
.minus { color: #f0a8a8; }
.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.title-row .title { margin-bottom: 0; }
.more { font-size: 25rpx; color: #D4AF37; }
.match-main { display: flex; flex-direction: column; flex: 1; }
.match-main .status { font-size: 23rpx; color: #8b92a8; margin-top: 4rpx; }
.delta { font-size: 27rpx; margin-left: 12rpx; }
.empty-hint { font-size: 25rpx; color: #8b92a8; text-align: center; padding: 16rpx 0; }
.status-tag { font-size: 23rpx; color: #c9cdd8; }

.login-wrap { padding-top: 48rpx; }
.login-card { text-align: center; padding: 48rpx 32rpx; }
.login-title { font-size: 35rpx; font-weight: bold; color: #f5f0e1; margin-bottom: 12rpx; }
.login-sub { font-size: 25rpx; color: #8b92a8; margin-bottom: 32rpx; }

.agree-row {
  display: flex;
  align-items: flex-start;
  text-align: left;
  margin: 0 0 24rpx;
  padding: 20rpx;
  border-radius: 14rpx;
  background: rgba(10, 15, 26, 0.45);
  border: 1rpx solid rgba(212, 175, 55, 0.15);
}

.agree-check {
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  margin-top: 4rpx;
  border-radius: 8rpx;
  border: 2rpx solid rgba(212, 175, 55, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.agree-check-on {
  background: linear-gradient(135deg, #f5e6b8, #D4AF37);
  border-color: #D4AF37;
}

.agree-check-icon {
  font-size: 24rpx;
  font-weight: bold;
  color: #0A0F1A;
  line-height: 1;
}

.agree-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.65;
  color: #c9cdd8;
}

.agree-plain {
  color: #c9cdd8;
}

.agree-link {
  color: #D4AF37;
  text-decoration: underline;
}

.btn-wx-login {
  width: 100% !important;
  margin: 16rpx 0;
  padding: 24rpx;
  line-height: 1.4;
  font-size: 29rpx;
  background: linear-gradient(135deg, #f5e6b8, #D4AF37, #a88625);
  color: #0A0F1A;
  border: none;
  border-radius: 18rpx;
  box-shadow: 0 10rpx 28rpx rgba(212, 175, 55, 0.32);
}
.btn-wx-login::after { border: none; }
.btn-wx-login-disabled {
  opacity: 0.45;
  box-shadow: none;
}
.login-hint { font-size: 23rpx; color: #8b92a8; margin-top: 8rpx; line-height: 1.55; }
.login-privacy-links { margin-top: 16rpx; text-align: center; }
.profile-legal {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  margin-top: 24rpx;
  padding: 16rpx 0;
}
.legal-link {
  font-size: 24rpx;
  color: #8b92a8;
  text-decoration: underline;
}
.legal-dot { font-size: 24rpx; color: #6b7280; }
.auth-fallback {
  margin-top: 32rpx;
  padding: 36rpx 28rpx 8rpx;
  border-top: 1rpx dashed rgba(212, 175, 55, 0.2);
  border-radius: 20rpx;
  background: rgba(10, 15, 26, 0.35);
}
.avatar-picker {
  background: transparent;
  padding: 0;
  margin: 0 auto 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 200rpx;
}
.avatar-picker::after { border: none; }
.user-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(212, 175, 55, 0.45);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.25);
}
.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx dashed rgba(212, 175, 55, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  color: #8b92a8;
  box-sizing: border-box;
}
.avatar-tip {
  font-size: 26rpx;
  color: #c9cdd8;
  margin-top: 16rpx;
  line-height: 1.4;
}
.nickname-input {
  width: 100%;
  box-sizing: border-box;
  margin: 0 0 24rpx;
  padding: 0 32rpx;
  min-height: 96rpx;
  line-height: 96rpx;
  font-size: 30rpx;
  background: rgba(10, 15, 26, 0.55);
  border-radius: 18rpx;
  color: #f5f0e1;
  text-align: center;
  border: 2rpx solid rgba(212, 175, 55, 0.3);
}
.btn-shop-card {
  text-align: center;
  margin-top: 8rpx;
}
.btn-shop-text {
  display: block;
  font-size: 31rpx;
  font-weight: 600;
  color: #D4AF37;
  letter-spacing: 2rpx;
}
.btn-logout { margin: 24rpx 28rpx 0; text-align: center; font-size: 25rpx; color: #8b92a8; text-decoration: underline; }
