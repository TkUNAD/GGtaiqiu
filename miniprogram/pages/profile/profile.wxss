.profile-card { text-align: center; }
.avatar { width: 120rpx; height: 120rpx; border-radius: 50%; margin-bottom: 16rpx; border: 4rpx solid #A78BFA; }
.name { font-size: 36rpx; font-weight: bold; }
.tier { color: #C4B5FD; margin: 8rpx 0; }
.score { color: #BFDBFE; }
.stats { font-size: 26rpx; color: #A5B4FC; margin-top: 12rpx; }
.match-row, .log-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
  font-size: 26rpx;
}
.plus { color: #93C5FD; }
.minus { color: #F472B6; }
.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.title-row .title { margin-bottom: 0; }
.more { font-size: 24rpx; color: #A78BFA; }
.tappable { cursor: pointer; }
.match-main { display: flex; flex-direction: column; flex: 1; }
.match-main .status { font-size: 22rpx; color: #93C5FD; margin-top: 4rpx; }
.delta { font-size: 26rpx; margin-left: 12rpx; }
.empty-hint { font-size: 24rpx; color: #A5B4FC; text-align: center; padding: 16rpx 0; }
input { background: rgba(0, 0, 0, 0.25); padding: 16rpx; border-radius: 8rpx; margin: 12rpx 0; color: #fff; border: 1rpx solid rgba(167, 139, 250, 0.3); }
.nickname-input {
  padding: 30rpx 20rpx;
  min-height: 90rpx;
  line-height: 1.5;
  font-size: 30rpx;
  box-sizing: border-box;
}
