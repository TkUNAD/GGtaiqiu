<view class="admin-page" wx:if="{{!loading && session}}">
  <view class="admin-header">
    <view class="admin-title">{{consoleTitle}}</view>
    <view class="admin-sub">{{roleLabel}} · {{consoleSubtitle}}</view>
    <view class="admin-tip" wx:if="{{session.member_tip}}">{{session.member_tip}}</view>
  </view>

  <view class="stats-row" wx:if="{{isVenueConsole && badges}}">
    <view class="stat-box">
      <text class="stat-num">{{badges.pending_matches || 0}}</text>
      <text class="stat-lbl">对局待审</text>
    </view>
    <view class="stat-box">
      <text class="stat-num">{{badges.pending_bonus_reviews || 0}}</text>
      <text class="stat-lbl">炸清待审</text>
    </view>
    <view class="stat-box">
      <text class="stat-num">{{badges.pending_exchanges || 0}}</text>
      <text class="stat-lbl">兑换待审</text>
    </view>
  </view>

  <view class="menu-grid">
    <view
      class="menu-item"
      wx:for="{{menu}}"
      wx:key="id"
      bindtap="openModule"
      data-id="{{item.id}}"
    >
      <text class="menu-badge" wx:if="{{item.badge > 0}}">{{item.badge}}</text>
      <text class="menu-item-title">{{item.title}}</text>
      <text class="menu-item-desc">{{item.desc}}</text>
    </view>
  </view>

  <view class="btn-logout-admin" bindtap="onLogout">退出管理后台</view>
</view>

<view class="empty-hint" wx:else>{{loading ? '加载中...' : '未登录'}}</view>
