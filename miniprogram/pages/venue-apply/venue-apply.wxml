<view class="container">

  <view class="card">

    <view class="title">俱乐部管理账号申请</view>

    <view class="hint">登录账号为手机号；提交后由总后台审核。审核通过后 30 天内无操作将自动注销。</view>

    <view class="field">

      <text class="label">俱乐部名称</text>

      <input class="input" placeholder="俱乐部全称" value="{{clubName}}" bindinput="onClub" />

    </view>

    <view class="field">

      <text class="label">登录密码</text>

      <input class="input" password placeholder="至少6位" value="{{password}}" bindinput="onPwd" />

    </view>

    <view class="field">

      <text class="label">确认密码</text>

      <input class="input" password value="{{confirm}}" bindinput="onConfirm" />

    </view>

    <view class="field row captcha-row">

      <input class="input flex1" placeholder="图形验证码" value="{{captchaCode}}" bindinput="onCaptcha" />

      <image class="captcha-img" src="{{captchaImg}}" bindtap="loadCaptcha" mode="aspectFit" />

    </view>

    <view class="field">

      <text class="label">手机号（登录账号）</text>

      <input class="input" type="number" maxlength="11" placeholder="11位手机号" value="{{phone}}" bindinput="onPhone" />

    </view>

    <button class="btn-primary" bindtap="onSubmit" loading="{{submitting}}">提交申请</button>

    <navigator class="link" url="/pages/venue-reset/venue-reset">已有账号？重置密码</navigator>

  </view>

</view>


