.container { padding: 24rpx; }
.card { padding: 32rpx; border-radius: 20rpx; background: #181f32; border: 1rpx solid rgba(212,175,55,0.25); }
.title { font-size: 34rpx; font-weight: bold; color: #D4AF37; margin-bottom: 12rpx; }
.hint { font-size: 24rpx; color: #8b92a8; margin-bottom: 28rpx; }
.field { margin-bottom: 24rpx; }
.label { display: block; font-size: 24rpx; color: #8b92a8; margin-bottom: 8rpx; }
.input { background: #12182a; border: 1rpx solid rgba(212,175,55,0.2); border-radius: 12rpx; padding: 20rpx; color: #f5f0e1; font-size: 28rpx; }
.row { display: flex; align-items: center; gap: 16rpx; }
.flex1 { flex: 1; }
.btn-code { background: #374151; color: #e5e7eb; }
.captcha-row { align-items: center; }
.captcha-img { width: 220rpx; height: 80rpx; border-radius: 8rpx; flex-shrink: 0; }
.btn-primary { margin-top: 16rpx; background: linear-gradient(135deg, #f5e6b8, #D4AF37); color: #0A0F1A; }
.link { display: block; text-align: center; margin-top: 24rpx; font-size: 26rpx; color: #8b92a8; }
