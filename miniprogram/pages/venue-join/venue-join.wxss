.container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}
.card {
  background: rgba(18, 24, 42, 0.95);
  border: 1rpx solid rgba(212, 175, 55, 0.25);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}
.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #f3f4f6;
  margin-bottom: 12rpx;
}
.sub {
  font-size: 26rpx;
  color: #9ca3af;
  line-height: 1.6;
}
.venue-name {
  color: #d4af37;
  font-size: 32rpx;
  font-weight: 600;
  margin: 16rpx 0;
}
.btn-primary {
  background: linear-gradient(135deg, #d4af37, #b8860b);
  color: #0a0f1a;
  border: none;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 24rpx;
}
.btn-primary::after { border: none; }
.btn-secondary {
  margin-top: 16rpx;
  background: rgba(255,255,255,0.08);
  color: #e5e7eb;
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 12rpx;
}
.btn-secondary::after { border: none; }
.login-wrap .login-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #f3f4f6;
  margin-bottom: 8rpx;
}
.login-wrap .login-sub {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 24rpx;
}
.agree-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}
.agree-check {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #6b7280;
  border-radius: 8rpx;
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.agree-check-on {
  border-color: #d4af37;
  background: rgba(212, 175, 55, 0.2);
}
.agree-check-icon { color: #d4af37; font-size: 24rpx; }
.agree-text { flex: 1; font-size: 24rpx; color: #9ca3af; line-height: 1.5; }
.agree-link { color: #d4af37; }
.btn-wx-login-disabled { opacity: 0.45; }
.auth-fallback { margin-top: 24rpx; padding-top: 24rpx; border-top: 1rpx solid rgba(255,255,255,0.08); }
.avatar-picker {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: transparent;
  border: none;
  padding: 0;
  margin-bottom: 16rpx;
}
.avatar-picker::after { border: none; }
.user-avatar, .avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 2rpx dashed rgba(212,175,55,0.5);
}
.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #d4af37;
  font-size: 48rpx;
}
.avatar-tip { font-size: 22rpx; color: #9ca3af; margin-top: 8rpx; }
.nickname-input {
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 12rpx;
  padding: 20rpx;
  color: #f3f4f6;
  margin-bottom: 16rpx;
}
.hint-error { color: #f9a8d4; font-size: 26rpx; }
