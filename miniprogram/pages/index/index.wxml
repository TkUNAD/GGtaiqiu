<view class="container">
  <view class="card net-tip" wx:if="{{netError}}">
    <text class="net-title">网络未连接</text>
    <text class="net-msg">{{netError}}</text>
    <text class="net-url">当前接口：{{apiUrl}}</text>
    <view class="btn-primary" bindtap="retryNetwork">重新检测</view>
  </view>

  <view class="card hero" wx:if="{{loggedIn}}">
    <view class="today-stats">
      <view class="today-item">
        <text class="today-val">+{{todayScore}}</text>
        <text class="today-label">今日获得积分</text>
      </view>
      <view class="today-divider"></view>
      <view class="today-item">
        <text class="today-val">{{rankedRemainingDaily}}</text>
        <text class="today-label">今日剩余排位</text>
      </view>
    </view>
  </view>
  <view class="card hero guest-hint" wx:else>
    <text class="guest-text">登录后查看今日积分与排位次数</text>
    <view class="btn-secondary" bindtap="goProfile">去「我的」登录</view>
  </view>

  <!-- 炫酷 VS 扫码开台 -->
  <view class="card card-hero scan-float">
    <view class="scan-arena" bindtap="scanTable">
      <view class="scan-ring scan-ring-outer"></view>
      <view class="scan-ring scan-ring-inner"></view>
      <view class="scan-spark scan-spark-l"></view>
      <view class="scan-spark scan-spark-r"></view>
      <view class="scan-core">
        <text class="vs-text">VS</text>
        <view class="vs-shine"></view>
      </view>
    </view>
    <text class="scan-label">扫码开台对战</text>
    <text class="scan-tip">抢5/7/9/11/13 · 两名选手到场后点击「对战开始」</text>
  </view>

  <view class="card" wx:if="{{challengeTargets.length}}">
    <view class="title">可挑战玩家（高1~5名）</view>
    <view class="challenge-item" wx:for="{{challengeTargets}}" wx:key="id" bindtap="challenge" data-target="{{item}}">
      <image class="tier-img tier-img-sm" src="{{item.tierImage}}" mode="aspectFit" />
      <text class="challenge-text">第{{item.rank}}名 {{item.nickname}} · {{item.score}}分</text>
    </view>
  </view>
  <view class="card" wx:elif="{{loggedIn && challengeHint}}">
    <view class="title">可挑战玩家</view>
    <text class="tip">{{challengeHint}}</text>
  </view>

  <view class="card">
    <view class="title-row">
      <text class="title">本俱乐部 TOP10</text>
      <text class="more" bindtap="goRank">完整榜单 ›</text>
    </view>
    <view class="rank-row" wx:for="{{topRank}}" wx:key="id" bindtap="showPlayer" data-id="{{item.id}}">
      <text class="rank-icon" wx:if="{{item.rankIcon}}">{{item.rankIcon}}</text>
      <text class="num" wx:else>{{item.club_rank || item.rank}}</text>
      <image class="tier-img tier-img-sm" src="{{item.tierImage}}" mode="aspectFit" />
      <text class="name">{{item.nickname}}</text>
      <text class="score">{{item.score}}</text>
    </view>
    <view wx:if="{{!topRank.length}}" class="empty-hint">暂无排行</view>
  </view>

  <view class="card">
    <view class="title">桌台状态</view>
    <view class="table-row" wx:for="{{tables}}" wx:key="id">
      <text>{{item.name}}</text>
      <text class="{{item.opened ? 'open' : 'closed'}}">{{item.opened ? '已开台' : '未开台'}}</text>
    </view>
    <view wx:if="{{!tables.length}}" class="empty-hint">暂无桌台</view>
  </view>
</view>

<view class="player-mask" wx:if="{{playerDetail}}" bindtap="closePlayer">
  <view class="player-panel card" catchtap="noop">
    <image class="player-avatar" src="{{playerDetail.avatar || '/assets/default-avatar.png'}}" mode="aspectFill" />
    <view class="player-name">{{playerDetail.nickname}}</view>
    <view class="tier-line">
      <image class="tier-img tier-img-lg" src="{{playerDetail.tierImage}}" mode="aspectFit" />
      <text class="player-tier">{{playerDetail.tier_name}} {{playerDetail.star}}星</text>
    </view>
    <view class="player-stats">
      <text>场次 {{playerDetail.total_games}}</text>
      <text>胜率 {{playerDetail.win_rate}}%</text>
      <text>胜{{playerDetail.wins}} 负{{playerDetail.losses}}</text>
    </view>
    <view class="btn-secondary" bindtap="closePlayer">关闭</view>
  </view>
</view>
