/* 首页：布局与动效（颜色由 app.wxss 统一） */
.net-tip { border-color: rgba(212, 175, 55, 0.35) !important; }
.net-title { display: block; font-size: 31rpx; font-weight: bold; color: #f5e6b8; margin-bottom: 12rpx; }
.net-msg { display: block; font-size: 25rpx; color: #c9cdd8; line-height: 1.6; margin-bottom: 8rpx; }
.net-url { display: block; font-size: 23rpx; color: #8b92a8; word-break: break-all; margin-bottom: 16rpx; }

.hero { margin-top: 8rpx; }

.today-stats { display: flex; align-items: center; justify-content: space-around; padding: 8rpx 0; }
.today-item { text-align: center; flex: 1; }
.today-divider {
  width: 1rpx;
  height: 64rpx;
  background: linear-gradient(180deg, transparent, rgba(212, 175, 55, 0.6), transparent);
}
.today-val { display: block; font-size: 45rpx; font-weight: 800; color: #D4AF37; }
.today-label { display: block; font-size: 25rpx; color: #8b92a8; margin-top: 8rpx; }
.guest-hint { text-align: center; }
.guest-text { display: block; color: #8b92a8; font-size: 27rpx; margin-bottom: 16rpx; }

.scan-float {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.scan-arena {
  position: relative;
  width: 300rpx;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.scan-ring { position: absolute; border-radius: 50%; border: 2rpx solid transparent; }
.scan-ring-outer {
  width: 100%;
  height: 100%;
  border-color: rgba(59, 130, 246, 0.22);
  border-top-color: #3B82F6;
  border-right-color: rgba(96, 165, 250, 0.65);
  border-bottom-color: rgba(37, 99, 235, 0.35);
  border-left-color: rgba(147, 197, 253, 0.45);
  box-shadow: 0 0 24rpx rgba(59, 130, 246, 0.25);
  animation: spin-slow 8s linear infinite;
}
.scan-ring-inner {
  width: 248rpx;
  height: 248rpx;
  border-color: rgba(59, 130, 246, 0.14);
  border-bottom-color: #2563EB;
  border-left-color: rgba(147, 197, 253, 0.5);
  border-top-color: rgba(96, 165, 250, 0.35);
  animation: spin-reverse 5s linear infinite;
}

.scan-spark {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #60A5FA;
  box-shadow: 0 0 16rpx rgba(59, 130, 246, 0.9);
}
.scan-spark-l { left: 24rpx; top: 50%; animation: pulse 1.5s ease-in-out infinite; }
.scan-spark-r { right: 24rpx; top: 50%; animation: pulse 1.5s ease-in-out 0.75s infinite; }

.scan-core {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    linear-gradient(145deg, rgba(212, 175, 55, 0.12) 0%, transparent 50%),
    linear-gradient(168deg, #1a2236 0%, #0A0F1A 100%);
  border: 3rpx solid rgba(212, 175, 55, 0.45);
  box-shadow:
    0 0 0 6rpx rgba(212, 175, 55, 0.08),
    0 0 36rpx rgba(212, 175, 55, 0.35),
    inset 0 0 28rpx rgba(212, 175, 55, 0.06);
}

.vs-text {
  font-size: 89rpx;
  font-weight: 900;
  font-style: italic;
  letter-spacing: -4rpx;
  line-height: 1;
  color: #f5e6b8;
  text-shadow: 0 0 28rpx rgba(212, 175, 55, 0.65), 0 4rpx 12rpx rgba(0, 0, 0, 0.5);
  position: relative;
  z-index: 2;
}

.vs-shine {
  position: absolute;
  width: 120%;
  height: 40rpx;
  top: 38%;
  left: -10%;
  background: linear-gradient(90deg, transparent, rgba(245, 230, 163, 0.45), transparent);
  transform: rotate(-12deg);
  z-index: 1;
  animation: shine-move 2.5s ease-in-out infinite;
}

.scan-label {
  margin-top: 28rpx;
  font-size: 31rpx;
  font-weight: bold;
  color: #f5f0e1;
  letter-spacing: 6rpx;
}
.scan-tip { font-size: 23rpx; color: #8b92a8; margin-top: 12rpx; text-align: center; }

@keyframes spin-slow {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
@keyframes spin-reverse {
  from { transform: rotate(360deg); }
  to { transform: rotate(0deg); }
}
@keyframes pulse {
  0%, 100% { opacity: 0.4; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1.2); }
}
@keyframes shine-move {
  0%, 100% { opacity: 0.3; transform: rotate(-12deg) translateX(-20%); }
  50% { opacity: 0.9; transform: rotate(-12deg) translateX(20%); }
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.title-row .title { margin-bottom: 0; }
.more { font-size: 25rpx; color: #D4AF37; }

.rank-row, .table-row, .challenge-item {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(212, 175, 55, 0.1);
  gap: 12rpx;
}
.challenge-text { flex: 1; color: #e8eaf0; }
.num { color: #8b92a8; width: 48rpx; text-align: center; font-size: 27rpx; font-weight: 600; }
.rank-icon { width: 48rpx; font-size: 33rpx; text-align: center; }
.name { flex: 1; color: #f5f0e1; }
.score { color: #D4AF37; font-weight: 600; }
.open { color: #86efac; }
.closed { color: #f0a8a8; }
.tip, .empty-hint { font-size: 25rpx; color: #8b92a8; }
.empty-hint { text-align: center; padding: 12rpx 0; }

.player-mask {
  position: fixed;
  left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(10, 15, 26, 0.85);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}
.player-panel { width: 100%; margin: 0 !important; text-align: center; }
.player-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(212, 175, 55, 0.5);
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 28rpx rgba(212, 175, 55, 0.2);
}
.player-name { font-size: 35rpx; font-weight: bold; color: #f5f0e1; }
.player-tier { color: #D4AF37; font-size: 29rpx; }
.player-stats {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  font-size: 27rpx;
  color: #c9cdd8;
  margin: 20rpx 0 24rpx;
}
