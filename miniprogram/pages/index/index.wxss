.container { padding-bottom: 40rpx; }
.net-tip {
  margin: 20rpx;
  padding: 24rpx;
  background: rgba(190, 24, 93, 0.35);
  border: 1rpx solid #f472b6;
  border-radius: 12rpx;
}
.net-title { display: block; font-size: 30rpx; font-weight: bold; color: #fce7f3; margin-bottom: 12rpx; }
.net-msg { display: block; font-size: 24rpx; color: #fbcfe8; line-height: 1.6; margin-bottom: 8rpx; }
.net-url { display: block; font-size: 22rpx; color: #e9d5ff; word-break: break-all; margin-bottom: 16rpx; }
.hero { text-align: center; }
.btn-primary.disabled { opacity: 0.6; }
.dev-login { margin-top: 24rpx; padding-top: 20rpx; border-top: 1rpx dashed rgba(255,255,255,0.25); }
.dev-label { display: block; font-size: 22rpx; color: #A5B4FC; margin-bottom: 12rpx; text-align: center; }
.dev-btns { display: flex; gap: 16rpx; }
.btn-test {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: rgba(124, 58, 237, 0.5);
  border: 1rpx solid #C4B5FD;
  border-radius: 12rpx;
  font-size: 26rpx;
}
.btn-logout {
  margin-top: 16rpx;
  text-align: center;
  font-size: 24rpx;
  color: #F9A8D4;
  text-decoration: underline;
}
.tip { font-size: 24rpx; color: #A5B4FC; display: block; margin-top: 12rpx; }
.rank-row, .table-row, .challenge-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.12);
}
.num { color: #E9D5FF; width: 60rpx; text-align: center; }
.rank-icon { width: 60rpx; font-size: 36rpx; text-align: center; }
.score { color: #BFDBFE; }
.open { color: #93C5FD; }
.closed { color: #F472B6; }
.challenge-item { color: #C4B5FD; }
