page {
  background: linear-gradient(180deg, #6B21A8 0%, #4F46E5 35%, #2563EB 70%, #1E3A8A 100%);
  background-attachment: fixed;
  min-height: 100vh;
  color: #E8EAF6;
  font-size: 28rpx;
}
.btn-primary {
  background: linear-gradient(180deg, #9333EA, #3B82F6);
  color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
  margin: 16rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.35);
}
.btn-secondary {
  background: linear-gradient(180deg, #5B21B6, #3730A3);
  color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
  margin: 16rpx 0;
}
.card {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 20rpx;
  border: 1rpx solid rgba(167, 139, 250, 0.4);
  backdrop-filter: blur(8px);
}
.title {
  font-size: 36rpx;
  color: #C4B5FD;
  font-weight: bold;
  margin-bottom: 16rpx;
}
